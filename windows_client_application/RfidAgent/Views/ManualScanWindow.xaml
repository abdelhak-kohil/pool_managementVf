<Window x:Class="RfidAgent.Views.ManualScanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manual Entry" Height="200" Width="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F8FAFC">
    
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Manual Check-In" FontSize="18" FontWeight="SemiBold" Foreground="#334155" Margin="0,0,0,15"/>
            
            <TextBox x:Name="InputBox" Padding="10" FontSize="16" Margin="0,0,0,20" 
                     BorderBrush="#CBD5E1" Background="White"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="80" Height="35" Margin="0,0,10,0" Click="Cancel_Click" Background="Transparent" BorderThickness="0" Foreground="#64748B"/>
                <Button Content="Check In" Width="100" Height="35" Click="Submit_Click" Background="#10B981" Foreground="White" FontWeight="Bold" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
