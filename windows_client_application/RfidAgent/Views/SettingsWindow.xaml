<Window x:Class="RfidAgent.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RfidAgent.Views"
        xmlns:vm="clr-namespace:RfidAgent.ViewModels"
        mc:Ignorable="d"
        Title="Configuration" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        FontFamily="Segoe UI Variable Display, Segoe UI">
    
    <Window.DataContext>
        <vm:SettingsViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <local:ModeToBoolConverter x:Key="ModeToBool" />
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,10"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,10,0,10"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,5"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Tabs -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="20">
            <StackPanel>
                <TextBlock Text="Settings" FontSize="24" FontWeight="SemiBold" Foreground="#0F172A"/>
                <TextBlock Text="Configure your RFID Agent parameters" FontSize="14" Foreground="#64748B" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="20" Background="Transparent" BorderThickness="0">
            
            <!-- 1. GENERAL TAB (Merged App, Attendance, Security) -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        
                        <GroupBox Header="Application Preferences">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Agent Name"/>
                                        <TextBox Text="{Binding AppName}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Language"/>
                                        <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <CheckBox Content="Auto-start with Windows" IsChecked="{Binding AutoStart}"/>
                                <CheckBox Content="Enable Sound Feedback" IsChecked="{Binding EnableSound}"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Attendance Logic">
                            <StackPanel>
                                <CheckBox Content="Enable Member Check-In" IsChecked="{Binding EnableMemberCheckIn}"/>
                                <CheckBox Content="Enable Staff Check-In" IsChecked="{Binding EnableStaffCheckIn}"/>
                                <CheckBox Content="Allow Same RFID for Both" IsChecked="{Binding SameRfidForBoth}"/>
                                
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Double Check-In Gap (Minutes)" Margin="0,0,10,0"/>
                                    <TextBox Grid.Column="1" Text="{Binding CheckInGapMinutes}"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                         <GroupBox Header="Security &amp; Safety" BorderBrush="#FECACA">
                            <StackPanel>
                                <TextBlock Text="Emergency Controls" FontWeight="Bold" Foreground="#B91C1C" Margin="0,0,0,5"/>
                                <CheckBox Content="PANIC MODE (Disable All Readers)" IsChecked="{Binding PanicMode}" 
                                          Foreground="#B91C1C" FontWeight="Bold"/>
                            </StackPanel>
                        </GroupBox>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 2. DEVICE TAB -->
            <TabItem Header="Device (Reader)">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <GroupBox Header="Connection Mode">
                            <StackPanel>
                                <TextBlock Text="Select Reader Type"/>
                                <ComboBox ItemsSource="{Binding RfidModes}" SelectedItem="{Binding SelectedMode}" Margin="0,5,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Serial Port Configuration" IsEnabled="{Binding SelectedMode, Converter={StaticResource ModeToBool}, ConverterParameter=COM}">
                            <StackPanel>
                                <TextBlock Text="COM Port" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding AvailableComPorts}" SelectedItem="{Binding SelectedComPort}" Margin="0,0,0,15"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Baud Rate"/>
                                        <ComboBox ItemsSource="{Binding AvailableBaudRates}" SelectedItem="{Binding SelectedBaudRate}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Data Bits"/>
                                        <ComboBox ItemsSource="{Binding DataBitsOptions}" SelectedItem="{Binding SelectedDataBits}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,15,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Parity"/>
                                        <ComboBox ItemsSource="{Binding ParityOptions}" SelectedItem="{Binding SelectedParity}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Stop Bits"/>
                                        <ComboBox ItemsSource="{Binding StopBitsOptions}" SelectedItem="{Binding SelectedStopBits}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 3. CONNECTION TAB (API) -->
            <TabItem Header="Server Connection">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <GroupBox Header="API Endpoint">
                            <StackPanel>
                                <TextBlock Text="Server Base URL (e.g. http://192.168.1.10:8000/api)" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ApiBaseUrl}" Margin="0,0,0,10"/>
                                
                                <TextBlock Text="API Key (Access Token)" Margin="0,10,0,5"/>
                                <TextBox Text="{Binding ApiKey}" FontFamily="Consolas"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Device Identification">
                            <StackPanel>
                                <TextBlock Text="Device Unique ID (Used for traceability)" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding DeviceId}" IsReadOnly="True" Background="#F1F5F9" Foreground="#64748B"/>
                            </StackPanel>
                        </GroupBox>

                         <GroupBox Header="Network">
                            <StackPanel>
                                <TextBlock Text="Request Timeout (Seconds)" Margin="0,0,0,5"/>
                                <Slider Minimum="5" Maximum="60" Value="{Binding TimeoutSeconds}" AutoToolTipPlacement="TopLeft" TickFrequency="5" IsSnapToTickEnabled="True"/>
                                <TextBlock Text="{Binding TimeoutSeconds}" HorizontalAlignment="Right" Foreground="#64748B"/>
                            </StackPanel>
                        </GroupBox>

                        <Button Content="Test Connectivity" Command="{Binding TestConnectionCommand}" 
                                Height="40" Background="#3B82F6" Foreground="White" BorderThickness="0" FontWeight="Bold" Margin="0,10,0,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 4. LOGS TAB -->
            <TabItem Header="System Logs">
                <Grid Margin="0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Min Level:" Margin="0,0,10,0"/>
                        <ComboBox ItemsSource="{Binding LogLevels}" SelectedItem="{Binding SelectedLogLevel}" Width="120"/>
                    </StackPanel>

                    <TextBox Grid.Row="1" Text="{Binding LogContent, Mode=OneWay}" 
                                IsReadOnly="True" VerticalScrollBarVisibility="Auto" 
                                FontFamily="Consolas" FontSize="12" Background="#0F172A" Foreground="#E2E8F0" Padding="10"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Refresh" Command="{Binding RefreshLogsCommand}" Width="80" Margin="0,0,10,0"/>
                        <Button Content="Open Folder" Command="{Binding OpenLogsFolderCommand}" Width="100" Margin="0,0,10,0"/>
                        <Button Content="Clear All" Command="{Binding ClearLogsCommand}" Width="80" Background="#EF4444" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Command="{Binding CloseCommand}" Width="100" Margin="0,0,10,0"
                        Background="Transparent" BorderBrush="#CBD5E1" BorderThickness="1"/>
                <Button Content="Save &amp; Apply" Command="{Binding SaveCommand}" Width="150" 
                        Background="#10B981" Foreground="White" BorderThickness="0" FontWeight="Bold">
                    <Button.Resources>
                         <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

    </Grid>
</Window>
