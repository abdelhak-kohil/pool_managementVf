<Window x:Class="RfidAgent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RfidAgent"
        xmlns:vm="clr-namespace:RfidAgent.ViewModels"
        mc:Ignorable="d"
        Title="Gym Manager | RFID Agent" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI Variable Display, Segoe UI">



    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:StringToVisibilityConverter x:Key="StringToVis" />
        <DropShadowEffect x:Key="CardShadow" BlurRadius="30" ShadowDepth="10" Direction="270" Color="#000" Opacity="0.15"/>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="50" ResizeBorderThickness="5" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Border Background="#F1F5F9" CornerRadius="12" BorderBrush="#CBD5E1" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- FEEDBACK OVERLAY (Full Screen Flash) -->
            <Grid x:Name="FeedbackOverlay" Grid.RowSpan="3" Panel.ZIndex="999" 
                  Visibility="{Binding IsFeedbackActive, Converter={StaticResource BoolToVis}}" 
                  IsHitTestVisible="False">
                <Border Background="{Binding BackgroundColor}" Opacity="0.95" CornerRadius="12">
                   <!-- Content Omitted for brevity, logic remains same -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="64" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="30"/>
                        <TextBlock Text="{Binding StatusSubMessage}" Foreground="White" FontSize="32" HorizontalAlignment="Center" Opacity="0.9" TextAlignment="Center" TextWrapping="Wrap" Visibility="{Binding StatusSubMessage, Converter={StaticResource StringToVis}}"/>
                        
                         <!-- MEMBER DETAILS -->
                        <StackPanel Margin="0,30,0,0" Visibility="{Binding HasMember, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding CurrentMember.FullName}" Foreground="White" FontSize="48" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                <Border Background="White" CornerRadius="8" Padding="15,5" Margin="5">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📅 " FontSize="20"/>
                                        <TextBlock Text="{Binding CurrentMember.PlanName}" Foreground="#334155" FontSize="20" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>



            <!-- 1. HEADER -->
            <Grid Grid.Row="0" Background="White" Height="60" MouseLeftButtonDown="Header_MouseDown">
                <Grid.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Color="#000" Opacity="0.05"/>
                </Grid.Effect>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Brand -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <Border Background="#2563EB" Width="8" Height="30" CornerRadius="4" Margin="0,0,10,0"/>
                    <TextBlock Text="GYM" FontWeight="ExtraBold" FontSize="20" Foreground="#0F172A"/>
                    <TextBlock Text="MANAGER" FontWeight="Light" FontSize="20" Foreground="#64748B" Margin="5,0,0,0"/>
                </StackPanel>

                <!-- Window Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,15,0" WindowChrome.IsHitTestVisibleInChrome="True">
                     <!-- Settings Button -->
                    <Button Command="{Binding OpenSettingsCommand}" Margin="0,0,15,0" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="16" Foreground="#94A3B8" VerticalAlignment="Center"/>
                            <TextBlock Text="Config" FontSize="12" Foreground="#94A3B8" Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Command="{Binding OpenManualEntryCommand}" Margin="0,0,15,0" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Manual Check-In">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Manual" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Button Click="Minimize_Click" Content="—" Width="40" Height="40" Background="Transparent" BorderThickness="0" FontSize="16" Foreground="#64748B"/>
                    <Button Click="Maximize_Click" Content="☐" Width="40" Height="40" Background="Transparent" BorderThickness="0" FontSize="16" Foreground="#64748B"/>
                    <Button Click="Close_Click" Content="✕" Width="40" Height="40" Background="Transparent" BorderThickness="0" FontSize="16" Foreground="#EF4444" FontWeight="Bold"/>
                </StackPanel>
            </Grid>

            <!-- 2. MAIN CONTENT -->
            <Grid Grid.Row="1">
                <!-- Idle State / Ready -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    
                    <!-- Only show if NO feedback is active -->
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                             <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Opacity" Value="0.2"/>
                                </DataTrigger>
                             </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Border Background="White" Width="500" CornerRadius="20" Padding="40" Effect="{StaticResource CardShadow}">
                        <StackPanel>
                             <TextBlock Text="Ready to Scan" FontSize="24" FontWeight="SemiBold" Foreground="#334155" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                             
                             <Border BorderBrush="#E2E8F0" BorderThickness="2" CornerRadius="10" Background="#F8FAFC" Height="200" Width="300" HorizontalAlignment="Center">
                                 <StackPanel VerticalAlignment="Center">
                                     <!-- Icon or Graphic -->
                                     <TextBlock Text="📡" FontSize="60" HorizontalAlignment="Center" Opacity="0.5"/>
                                     <TextBlock Text="Present Badge to Reader" FontSize="16" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                                 </StackPanel>
                             </Border>

                             <!-- Busy Indicator (Overlaying text if busy) -->
                             <TextBlock Text="Processing..." FontSize="18" Foreground="#2563EB" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,0"
                                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- 3. FOOTER -->
            <Grid Grid.Row="2" Background="White" Height="40">
                 <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <Ellipse Width="8" Height="8" Fill="{Binding SystemStatusColor}" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding SystemStatus}" FontSize="12" Foreground="{Binding SystemStatusColor}" FontWeight="SemiBold"/>
                    <TextBlock Text=" | " Foreground="#CBD5E1" Margin="10,0"/>
                    <Ellipse Width="8" Height="8" Fill="{Binding ReaderStatusColor}" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding ReaderStatus}" FontSize="12" Foreground="{Binding ReaderStatusColor}" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="v1.0.0" FontSize="12" Foreground="#CBD5E1"/>
                </StackPanel>
            </Grid>

        </Grid>
    </Border>
</Window>
