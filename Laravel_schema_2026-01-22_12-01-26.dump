    sessions_per_week integer,
    status character varying(255) DEFAULT 'draft'::character varying NOT NULL,
    CONSTRAINT partner_contracts_billing_frequency_check CHECK (((billing_frequency)::text = ANY ((ARRAY['per_session'::character varying, 'weekly'::character varying, 'monthly'::character varying, 'annually'::character varying])::text[]))),
    CONSTRAINT partner_contracts_contract_type_check CHECK (((contract_type)::text = ANY (ARRAY['discount'::text, 'fixed_price'::text, 'flat_fee'::text, 'per_head'::text, 'fixed_package'::text, 'monthly_weekly'::text, 'per_session'::text]))),
    CONSTRAINT partner_contracts_payment_status_check CHECK (((payment_status)::text = ANY ((ARRAY['pending'::character varying, 'paid'::character varying])::text[]))),
    CONSTRAINT partner_contracts_status_check CHECK (((status)::text = ANY ((ARRAY['draft'::character varying, 'pending_payment'::character varying, 'active'::character varying, 'suspended'::character varying, 'finished'::character varying])::text[])))
);


ALTER TABLE pool_schema.partner_contracts OWNER TO pooladmin;

